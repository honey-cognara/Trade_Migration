# Copy this to .env and fill in your values
# NEVER commit .env to version control

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/tradie_migration

# ── JWT Auth ───────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET

# ── OpenAI ─────────────────────────────────────────────────────────────────────
# Required for RAG embeddings and LLM answers (set USE_STUB_EMBEDDINGS=true for local dev)
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini

# ── RAG / Embeddings ───────────────────────────────────────────────────────────
# Set to "true" for local dev without an OpenAI key (uses zero vectors — no real AI)
# Set to "false" in production so real embeddings and answers are generated
USE_STUB_EMBEDDINGS=true

# ── File Storage ───────────────────────────────────────────────────────────────
# Absolute path to the local uploads directory.
# Defaults to <project_root>/uploads/ if not set.
# In production point this to a persistent volume.
# UPLOADS_DIR=/var/data/tradie-uploads

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
